{
  "name": "bot-system",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "server": "ts-node-dev --respawn --transpile-only src/server.ts",
    "bot": "ts-node-dev --respawn --transpile-only src/bot/bot.ts",
    "dev": "concurrently -n SERVER,BOT -c blue,green \"npm run server\" \"npm run bot\"",
    "build": "tsc",
    "start": "node dist/server.js & node dist/bot/bot.js",
    "start:bot": "node dist/bot/bot.js",
    "start:prod": "concurrently \"npm run start\" \"npm run start:bot\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
